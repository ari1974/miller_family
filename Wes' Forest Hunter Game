<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forest Hunter - JS Edition</title>
</head>
<body>
    <script>
        /**
         * Forest Hunter: Entirely JavaScript Edition
         * Modified: Prey no longer speed up when fleeing.
         */

        // 1. --- STYLING & UI CONSTRUCTION ---
        const style = document.createElement('style');
        style.textContent = `
            body {
                margin: 0;
                overflow: hidden;
                background-color: #1a2a1a;
                display: flex;
                justify-content: center;
                align-items: center;
                height: 100vh;
                font-family: 'Courier New', Courier, monospace;
                color: white;
            }
            canvas {
                background-color: #2a402a;
                display: block;
                border-radius: 12px;
                box-shadow: 0 0 30px rgba(0,0,0,0.6);
            }
            #ui-container {
                position: absolute;
                top: 25px;
                left: 50%;
                transform: translateX(-50%);
                display: none;
                gap: 30px;
                background-color: rgba(0,0,0,0.7);
                padding: 12px 25px;
                border-radius: 10px;
                font-size: 20px;
                text-shadow: 2px 2px 4px #000;
                border: 2px solid #4a6319;
                pointer-events: none;
                z-index: 5;
                align-items: center;
                white-space: nowrap;
            }
            #volley-status {
                font-size: 14px;
                padding: 4px 8px;
                border-radius: 4px;
                background: #333;
                color: #777;
                border: 1px solid #555;
                transition: all 0.3s ease;
            }
            #volley-status.ready {
                background: #004d4d;
                color: #00fbff;
                border-color: #00fbff;
                box-shadow: 0 0 10px rgba(0, 251, 255, 0.4);
            }
            #hp-display { color: #ff4d4d; font-weight: bold; }
            #modal {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background-color: rgba(0, 0, 0, 0.95);
                padding: 40px;
                border-radius: 20px;
                text-align: center;
                box-shadow: 0 0 40px rgba(0,0,0,0.8);
                border: 3px solid #6b8e23;
                z-index: 10;
                max-width: 500px;
            }
            #modal h1 { font-size: 44px; margin-bottom: 15px; color: #8fbc3f; }
            #modal p { font-size: 15px; margin-bottom: 25px; line-height: 1.5; text-align: left; }
            #modal button {
                background: #6b8e23;
                color: white;
                border: none;
                padding: 18px 35px;
                font-size: 24px;
                border-radius: 10px;
                cursor: pointer;
                transition: all 0.2s ease;
                box-shadow: 0 6px #3a4d14;
                font-family: 'Courier New', Courier, monospace;
                font-weight: bold;
            }
            #modal button:hover { background-color: #8fbc3f; transform: scale(1.05); }
        `;
        document.head.appendChild(style);

        const canvas = document.createElement('canvas');
        canvas.id = 'gameCanvas';
        document.body.appendChild(canvas);

        const uiContainer = document.createElement('div');
        uiContainer.id = 'ui-container';
        uiContainer.innerHTML = `
            <div id="hp-display">HP: 5</div>
            <div id="xp-display">XP: 0</div>
            <div id="timer-display">Time: 2:30</div>
            <div id="volley-status">Volley: N/A</div>
        `;
        document.body.appendChild(uiContainer);

        const modal = document.createElement('div');
        modal.id = 'modal';
        modal.innerHTML = `
            <h1>Forest Hunter</h1>
            <p>
                <b>Arrows or WASD</b>: Move | <b>Space</b>: Shoot<br><br>
                • Health: You have <b>5 HP</b>. Don't let it reach 0!<br>
                • Regular Deer: 2 HP (15 XP)<br>
                • Pig: 4 HP (35 XP) - Look for the tiny pink dot!<br>
                • <b>Boar</b>: 5 HP (45-60 XP). <b>CAUTION</b>: Touching costs 1 HP & 10 XP/sec!<br>
                • <b>AI</b>: Deer and Pigs flee if shot. Boars do not react!<br>
                • Melee: Touch to deal 1 HP/sec damage to prey<br>
                • <b>Super Gun</b>: 10-Shot Volley, 2x Speed & Seeking shots!<br>
            </p>
            <button id="startButton">Start Hunt</button>
        `;
        document.body.appendChild(modal);

        const ctx = canvas.getContext('2d');
        const xpDisplay = uiContainer.querySelector('#xp-display');
        const hpDisplay = uiContainer.querySelector('#hp-display');
        const timerDisplay = uiContainer.querySelector('#timer-display');
        const volleyStatus = uiContainer.querySelector('#volley-status');
        const startButton = modal.querySelector('#startButton');

        // 2. --- GAME STATE ---
        const keys = {}; 
        let player, preyList, bullets, xp, timeLeft, gameInterval, spawnInterval, boarTimeout, pigTimeout, megaTimer;
        let gameOver = true;
        let smokeParticles = [];
        let gunDrops = [];

        const ROUND_TIME = 150; 
        const SPAWN_INTERVAL = 3000; 
        const VOLLEY_COOLDOWN = 3000; 

        function resizeCanvas() {
            canvas.width = window.innerWidth * 0.95;
            canvas.height = window.innerHeight * 0.85;
        }

        // 3. --- CLASSES ---

        class Player {
            constructor(x, y) {
                this.x = x; this.y = y; this.radius = 16;
                this.hp = 5; this.baseSpeed = 4; this.speed = 4;
                this.facing = 'right'; this.hasSuperGun = false;
                this.shotsFiredCount = 0; this.lastVolleyTime = 0;
            }
            draw() {
                ctx.beginPath(); ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fillStyle = '#8B4513'; ctx.fill();
                ctx.strokeStyle = '#3d2b1f'; ctx.lineWidth = 2; ctx.stroke();
                ctx.fillStyle = "white"; ctx.beginPath();
                let ex = this.x, ey = this.y;
                if(this.facing === 'right') ex += 8; else if(this.facing === 'left') ex -= 8;
                else if(this.facing === 'up') ey -= 8; else if(this.facing === 'down') ey += 8;
                ctx.arc(ex, ey, 3, 0, Math.PI*2); ctx.fill();
                ctx.save(); ctx.translate(this.x, this.y);
                let angle = 0;
                if (this.facing === 'down') angle = Math.PI/2; else if (this.facing === 'left') angle = Math.PI;
                else if (this.facing === 'up') angle = -Math.PI/2;
                ctx.rotate(angle);
                const isSuper = this.hasSuperGun;
                ctx.fillStyle = isSuper ? '#00fbff' : '#555'; ctx.strokeStyle = isSuper ? '#00fbff' : '#555';
                if (isSuper) { ctx.shadowBlur = 15; ctx.shadowColor = '#00fbff'; }
                const gW = isSuper ? 36 : 28; const gH = isSuper ? 12 : 8;
                ctx.fillRect(this.radius, -gH/2, gW, gH);
                if (isSuper) {
                    ctx.lineWidth = 3;
                    ctx.beginPath(); ctx.moveTo(this.radius + 6, -gH/2 - 3); 
                    ctx.quadraticCurveTo(this.radius + gW/2, -gH - 12, this.radius + gW - 8, -gH/2 - 4); ctx.stroke();
                    ctx.beginPath(); ctx.moveTo(this.radius + 6, gH/2 + 3);
                    ctx.quadraticCurveTo(this.radius + gW/2, gH + 12, this.radius + gW - 8, gH/2 + 4); ctx.stroke();
                }
                ctx.restore();
            }
            update() {
                this.speed = this.hasSuperGun ? this.baseSpeed * 2 : this.baseSpeed;
                if ((keys['ArrowUp'] || keys['w'] || keys['W']) && this.y > this.radius) { this.y -= this.speed; this.facing = 'up'; }
                if ((keys['ArrowDown'] || keys['s'] || keys['S']) && this.y < canvas.height - this.radius) { this.y += this.speed; this.facing = 'down'; }
                if ((keys['ArrowLeft'] || keys['a'] || keys['A']) && this.x > this.radius) { this.x -= this.speed; this.facing = 'left'; }
                if ((keys['ArrowRight'] || keys['d'] || keys['D']) && this.x < canvas.width - this.radius) { this.x += this.speed; this.facing = 'right'; }
                if (this.hasSuperGun) {
                    const now = Date.now();
                    if (now - this.lastVolleyTime >= VOLLEY_COOLDOWN) { 
                        volleyStatus.textContent = "Volley: READY"; 
                        volleyStatus.classList.add('ready'); 
                    } else { 
                        const remaining = Math.ceil((VOLLEY_COOLDOWN - (now - this.lastVolleyTime)) / 1000); 
                        volleyStatus.textContent = `Volley: ${remaining}s`; 
                        volleyStatus.classList.remove('ready'); 
                    }
                } else { volleyStatus.textContent = "Volley: N/A"; }
            }
        }

        class Prey {
            constructor(x, y, type = 'deer') {
                this.x = x; this.y = y; this.type = type;
                this.lastMeleeTime = 0; this.behaviorState = 'normal'; this.behaviorTimer = 0;
                if (type === 'mega') { this.radius = 30; this.hp = 10; this.xpValue = 85; this.speed = 6.5; this.color = '#4b2e00'; }
                else if (type === 'boar') { this.radius = 18; this.hp = 5; this.xpValue = Math.random() < 0.15 ? 55 : 45; this.speed = 4.0; this.color = '#333333'; }
                else if (type === 'pig') { this.radius = 18; this.hp = 4; this.xpValue = 35; this.speed = 4.5; this.color = '#333333'; }
                else { this.radius = 15; this.hp = 2; this.xpValue = 15; this.speed = 5.2; this.color = '#A0522D'; }
                let angle = Math.random() * Math.PI * 2;
                this.dx = Math.cos(angle) * this.speed; this.dy = Math.sin(angle) * this.speed;
                this.changeTimer = Math.random() * 80 + 40;
            }
            triggerBehavior() {
                if (this.type === 'boar') return; 
                this.behaviorState = 'alert'; this.behaviorTimer = 600; 
            }
            draw() {
                ctx.beginPath(); ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fillStyle = this.color; ctx.fill();
                if (this.type === 'mega') { ctx.strokeStyle = '#FFD700'; ctx.lineWidth = 4; ctx.stroke(); }
                else if (this.type === 'boar' || this.type === 'pig') {
                    ctx.strokeStyle = '#666'; ctx.lineWidth = 2; ctx.stroke();
                    if (this.type === 'pig') {
                        ctx.beginPath(); ctx.arc(this.x, this.y - 5, 1.5, 0, Math.PI * 2); 
                        ctx.fillStyle = '#ffc0cb'; ctx.fill(); ctx.closePath();
                    }
                }
                ctx.closePath();
            }
            update() {
                const pad = 50;
                const centerLimit = 160; 
                
                // Regular speed used even during fleeing
                const moveSpeed = this.speed; 
                const isAlert = this.behaviorTimer > 0 && this.type !== 'boar';

                if (isAlert) {
                    this.behaviorTimer--;
                    // Fleeing logic
                    let fleeX = this.x - player.x;
                    let fleeY = this.y - player.y;

                    // Magnet logic to prevent corner trapping
                    let centerX = canvas.width / 2;
                    let centerY = canvas.height / 2;
                    let pullX = centerX - this.x;
                    let pullY = centerY - this.y;

                    let distToEdge = Math.min(this.x, canvas.width - this.x, this.y, canvas.height - this.y);
                    let pullWeight = 0;
                    if (distToEdge < centerLimit) {
                        pullWeight = (1 - distToEdge / centerLimit) * 0.85;
                    }

                    let finalDirX = fleeX * (1 - pullWeight) + pullX * pullWeight;
                    let finalDirY = fleeY * (1 - pullWeight) + pullY * pullWeight;

                    let mag = Math.hypot(finalDirX, finalDirY);
                    if (mag > 0) {
                        this.dx = (finalDirX / mag) * moveSpeed;
                        this.dy = (finalDirY / mag) * moveSpeed;
                    }

                    if (this.behaviorTimer <= 0) {
                        this.behaviorState = 'normal';
                        this.changeTimer = 0;
                    }
                } else {
                    // Normal Wandering Logic
                    this.changeTimer--;
                    if (this.changeTimer <= 0) {
                        let randAngle = Math.random() * Math.PI * 2;
                        if (this.x < centerLimit || this.x > canvas.width - centerLimit || 
                            this.y < centerLimit || this.y > canvas.height - centerLimit) {
                            randAngle = Math.atan2((canvas.height/2) - this.y, (canvas.width/2) - this.x) + (Math.random() - 0.5);
                        }
                        this.dx = Math.cos(randAngle) * this.speed;
                        this.dy = Math.sin(randAngle) * this.speed;
                        this.changeTimer = Math.random() * 80 + 40;
                    }
                }

                // Bounce Logic
                if (this.x + this.dx < pad) { this.x = pad; this.dx = Math.abs(this.dx); }
                if (this.x + this.dx > canvas.width - pad) { this.x = canvas.width - pad; this.dx = -Math.abs(this.dx); }
                if (this.y + this.dy < pad) { this.y = pad; this.dy = Math.abs(this.dy); }
                if (this.y + this.dy > canvas.height - pad) { this.y = canvas.height - pad; this.dy = -Math.abs(this.dy); }

                this.x += this.dx;
                this.y += this.dy;
                
                this.x = Math.max(pad, Math.min(canvas.width - pad, this.x));
                this.y = Math.max(pad, Math.min(canvas.height - pad, this.y));
            }
        }

        class Bullet {
            constructor(x, y, vx, vy, seeking = false) {
                this.x = x; this.y = y; this.vx = vx; this.vy = vy; this.radius = seeking ? 8 : 4;
                this.seeking = seeking; this.speed = 12;
            }
            update() {
                if (this.seeking && preyList.length > 0) {
                    let target = null; let minDist = Infinity;
                    preyList.forEach(d => {
                        let dist = Math.hypot(this.x - d.x, this.y - d.y);
                        if (dist < minDist) { minDist = dist; target = d; }
                    });
                    if (target) {
                        let angle = Math.atan2(target.y - this.y, target.x - this.x);
                        this.vx = Math.cos(angle) * this.speed; this.vy = Math.sin(angle) * this.speed;
                    }
                }
                this.x += this.vx; this.y += this.vy;
            }
            draw() {
                ctx.beginPath(); ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fillStyle = this.seeking ? '#00fbff' : '#FFFF00';
                if (this.seeking) { ctx.shadowBlur = 12; ctx.shadowColor = '#00fbff'; }
                ctx.fill(); ctx.shadowBlur = 0;
            }
        }

        class Smoke {
            constructor(x, y) {
                this.x = x; this.y = y; this.r = Math.random() * 6 + 4; this.opacity = 1;
                this.vx = (Math.random() - 0.5) * 2; this.vy = (Math.random() - 0.5) * 2;
            }
            update() { this.x += this.vx; this.y += this.vy; this.opacity -= 0.025; }
            draw() { ctx.globalAlpha = this.opacity; ctx.beginPath(); ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2); ctx.fillStyle = '#CCCCCC'; ctx.fill(); ctx.globalAlpha = 1; }
        }

        // 4. --- LOGIC LOOPS ---

        function spawnPrey(type = 'deer') {
            const pad = 80;
            const x = Math.random() * (canvas.width - pad * 2) + pad;
            const y = Math.random() * (canvas.height - pad * 2) + pad;
            preyList.push(new Prey(x, y, type));
        }

        function spawnBoarLoop() { if (gameOver) return; spawnPrey('boar'); boarTimeout = setTimeout(spawnBoarLoop, Math.random() * 5000 + 10000); }
        function spawnPigLoop() { if (gameOver) return; spawnPrey('pig'); pigTimeout = setTimeout(spawnPigLoop, 10000); }

        function init() {
            resizeCanvas();
            player = new Player(canvas.width/2, canvas.height/2);
            preyList = []; bullets = []; smokeParticles = []; gunDrops = [];
            xp = 0; timeLeft = ROUND_TIME; gameOver = false;
            uiContainer.style.display = 'flex';
            xpDisplay.textContent = `XP: 0`;
            hpDisplay.textContent = `HP: ${player.hp}`;
            spawnPrey('deer');
            
            if (gameInterval) clearInterval(gameInterval);
            gameInterval = setInterval(() => {
                timeLeft--;
                const m = Math.floor(timeLeft / 60); const s = timeLeft % 60;
                timerDisplay.textContent = `Time: ${m}:${s < 10 ? '0' : ''}${s}`;
                if (timeLeft <= 0) endGame("Time's Up!");
            }, 1000);
            
            if (spawnInterval) clearInterval(spawnInterval);
            spawnInterval = setInterval(() => { if (!gameOver) spawnPrey('deer'); }, SPAWN_INTERVAL);
            
            if (boarTimeout) clearTimeout(boarTimeout); spawnBoarLoop();
            if (pigTimeout) clearTimeout(pigTimeout); spawnPigLoop();
            if (megaTimer) clearTimeout(megaTimer);
            megaTimer = setTimeout(() => { if (!gameOver) spawnPrey('mega'); }, 40000);
            
            animate();
        }

        function animate() {
            if (gameOver) return; requestAnimationFrame(animate); ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#1e381e';
            [ {x:200,y:150}, {x:canvas.width-300,y:200}, {x:500,y:canvas.height-200}, {x:canvas.width-600,y:canvas.height-150} ].forEach(t => {
                ctx.beginPath(); ctx.arc(t.x, t.y, 60, 0, Math.PI*2); ctx.fill();
            });
            if (preyList.filter(p => p.type === 'deer').length === 0 && !gameOver) { for(let i=0; i<3; i++) spawnPrey('deer'); }
            player.update(); player.draw();
            smokeParticles.forEach((s, i) => { s.update(); s.draw(); if (s.opacity <= 0) smokeParticles.splice(i, 1); });
            gunDrops.forEach((g, i) => {
                ctx.fillStyle = '#00fbff'; ctx.save(); ctx.shadowBlur = 10; ctx.shadowColor = '#00fbff';
                ctx.fillRect(g.x-15, g.y-5, 30, 10); ctx.restore();
                if (Math.hypot(player.x - g.x, player.y - g.y) < player.radius + 15) { player.hasSuperGun = true; gunDrops.splice(i, 1); }
            });
            bullets.forEach((b, bi) => {
                b.update(); b.draw();
                preyList.forEach(p => { if (Math.hypot(b.x - p.x, b.y - p.y) < 60) p.triggerBehavior(); });
                if (b.x < -100 || b.x > canvas.width + 100 || b.y < -100 || b.y > canvas.height + 100) { bullets.splice(bi, 1); return; }
                preyList.forEach((d, di) => {
                    if (Math.hypot(b.x - d.x, b.y - d.y) < d.radius + b.radius) {
                        d.hp--; d.triggerBehavior(); bullets.splice(bi, 1);
                        if (d.hp <= 0) handlePreyDeath(di);
                    }
                });
            });
            preyList.forEach((d, di) => {
                d.update(); d.draw();
                const dist = Math.hypot(player.x - d.x, player.y - d.y);
                if (dist < player.radius + d.radius + 5) {
                    const now = Date.now();
                    if (now - d.lastMeleeTime > 1000) {
                        d.hp--; d.triggerBehavior();
                        if (d.type === 'boar') {
                            player.hp--; xp = Math.max(0, xp - 10);
                            hpDisplay.textContent = `HP: ${player.hp}`; xpDisplay.textContent = `XP: ${xp}`;
                            if (player.hp <= 0) endGame("Hunt Ended!");
                        }
                        d.lastMeleeTime = now;
                        if (d.hp <= 0) handlePreyDeath(di);
                    }
                }
            });
        }

        function handlePreyDeath(index) {
            const d = preyList[index]; 
            xp += d.xpValue; 
            xpDisplay.textContent = `XP: ${xp}`;
            if (d.type === 'mega') gunDrops.push({ x: d.x, y: d.y }); 
            preyList.splice(index, 1);
        }

        function endGame(reason) {
            gameOver = true; clearInterval(gameInterval); clearInterval(spawnInterval);
            clearTimeout(megaTimer); clearTimeout(boarTimeout); clearTimeout(pigTimeout);
            modal.style.display = 'block';
            modal.querySelector('h1').textContent = reason;
            modal.querySelector('p').innerHTML = `Final Score: <b>${xp} XP</b>`;
            startButton.textContent = "Hunt Again";
        }

        // 5. --- EVENT LISTENERS ---

        window.addEventListener('keydown', e => {
            keys[e.key] = true;
            if (e.key === ' ' && !gameOver) {
                e.preventDefault();
                let bA = 0;
                if (player.facing === 'up') bA = -Math.PI/2;
                else if (player.facing === 'down') bA = Math.PI/2;
                else if (player.facing === 'left') bA = Math.PI;
                
                const now = Date.now();
                const isVolley = player.hasSuperGun && (now - player.lastVolleyTime >= VOLLEY_COOLDOWN);
                const bC = isVolley ? 10 : 1;
                if (isVolley) player.lastVolleyTime = now;
                
                for (let i = 0; i < bC; i++) {
                    player.shotsFiredCount++;
                    let angle = bA + (isVolley ? (i / (bC - 1)) * (Math.PI/4) - (Math.PI/8) : 0);
                    bullets.push(new Bullet(player.x, player.y, Math.cos(angle) * 12, Math.sin(angle) * 12, player.hasSuperGun && (player.shotsFiredCount % 5 === 0)));
                }
                for(let i=0; i<10; i++) smokeParticles.push(new Smoke(player.x, player.y));
            }
        });

        window.addEventListener('keyup', e => { keys[e.key] = false; });
        startButton.addEventListener('click', () => { modal.style.display = 'none'; init(); });
        window.addEventListener('resize', resizeCanvas);
        
        resizeCanvas();

    </script>
</body>
</html>
