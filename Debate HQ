<script>
// ==================== Navigation ====================
const navButtons = document.querySelectorAll('.nav-btn');
const panels = document.querySelectorAll('.panel');

navButtons.forEach(btn => {
  btn.addEventListener('click', () => {
    navButtons.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const panelId = btn.dataset.panel;
    panels.forEach(p => p.classList.remove('active'));
    document.getElementById('panel-' + panelId).classList.add('active');
    window.scrollTo(0, 0);
  });
});

// ==================== Card expand/collapse ====================
document.querySelectorAll('.card-head').forEach(head => {
  head.addEventListener('click', () => {
    head.parentElement.classList.toggle('open');
  });
});

// ==================== Timers ====================
function createTimer(displayId, startId, pauseId, resetId, defaultSeconds, countDown) {
  const display = document.getElementById(displayId);
  const startBtn = document.getElementById(startId);
  const pauseBtn = document.getElementById(pauseId);
  const resetBtn = document.getElementById(resetId);

  let seconds = defaultSeconds;
  let initialSeconds = defaultSeconds;
  let running = false;
  let intervalId = null;

  function format(s) {
    if (s < 0) s = 0;
    const m = Math.floor(s / 60);
    const rem = s % 60;
    return m + ':' + (rem < 10 ? '0' : '') + rem;
  }

  function updateDisplay() {
    display.textContent = format(seconds);
    display.classList.remove('warn', 'crit');
    if (countDown) {
      if (seconds <= 10 && seconds > 0) display.classList.add('crit');
      else if (seconds <= 30 && seconds > 10) display.classList.add('warn');
    } else {
      const remaining = initialSeconds - seconds;
      if (initialSeconds > 0 && remaining <= 10 && remaining > 0) display.classList.add('crit');
      else if (initialSeconds > 0 && remaining <= 30 && remaining > 10) display.classList.add('warn');
    }
  }

  function tick() {
    if (countDown) {
      seconds--;
      if (seconds <= 0) {
        seconds = 0;
        stop();
      }
    } else {
      seconds++;
      if (initialSeconds > 0 && seconds >= initialSeconds) {
        stop();
      }
    }
    updateDisplay();
  }

  function start() {
    if (running) return;
    running = true;
    intervalId = setInterval(tick, 1000);
  }
  function stop() {
    running = false;
    if (intervalId) {
      clearInterval(intervalId);
      intervalId = null;
    }
  }
  function reset(newSeconds) {
    stop();
    seconds = newSeconds !== undefined ? newSeconds : defaultSeconds;
    initialSeconds = seconds;
    updateDisplay();
  }

  startBtn.addEventListener('click', start);
  pauseBtn.addEventListener('click', stop);
  resetBtn.addEventListener('click', () => reset(defaultSeconds));

  updateDisplay();
  return { start, stop, reset, isRunning: () => running,
           setTarget: (s) => { reset(countDown ? s : 0); initialSeconds = s; updateDisplay(); } };
}

const prepTimer = createTimer('prep-display', 'prep-start', 'prep-pause', 'prep-reset', 240, true);
const speechTimer = createTimer('speech-display', 'speech-start', 'speech-pause', 'speech-reset', 0, false);

// Preset buttons for speech timer
document.querySelectorAll('.preset-row button').forEach(btn => {
  btn.addEventListener('click', () => {
    const s = parseInt(btn.dataset.seconds, 10);
    speechTimer.setTarget(s);
  });
});

// ==================== Keyboard shortcuts ====================
document.addEventListener('keydown', (e) => {
  if (e.target.tagName === 'TEXTAREA' || e.target.tagName === 'INPUT') return;
  if (e.key === ' ') {
    e.preventDefault();
    if (prepTimer.isRunning()) prepTimer.stop();
    else if (speechTimer.isRunning()) speechTimer.stop();
    else speechTimer.start();
  } else if (e.key === 'r' || e.key === 'R') {
    speechTimer.reset(0);
  }
});

// ==================== Scouting ====================
const scoutContainer = document.getElementById('scout-entries');
const addScoutBtn = document.getElementById('add-scout');
let scoutData = [];

function renderScouting() {
  scoutContainer.innerHTML = '';
  scoutData.forEach((entry, idx) => {
    const div = document.createElement('div');
    div.className = 'scout-entry';
    div.innerHTML =
      '<input data-idx="' + idx + '" data-field="name" placeholder="Opponent name / school" value="' + escapeHtml(entry.name) + '">' +
      '<input data-idx="' + idx + '" data-field="case" placeholder="Case type (Locke AFF / Chenoweth NEG / etc)" value="' + escapeHtml(entry.caseType) + '">' +
      '<textarea data-idx="' + idx + '" data-field="notes" placeholder="Notes: arguments, style, tells, what worked, what didn\'t">' + escapeHtml(entry.notes) + '</textarea>' +
      '<button class="btn-small danger" data-idx="' + idx + '" style="margin-top: 6px;">Delete</button>';
    scoutContainer.appendChild(div);
  });

  scoutContainer.querySelectorAll('input, textarea').forEach(el => {
    el.addEventListener('input', () => {
      const idx = parseInt(el.dataset.idx, 10);
      const field = el.dataset.field;
      if (field === 'name') scoutData[idx].name = el.value;
      else if (field === 'case') scoutData[idx].caseType = el.value;
      else if (field === 'notes') scoutData[idx].notes = el.value;
    });
  });
  scoutContainer.querySelectorAll('button.danger').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.idx, 10);
      scoutData.splice(idx, 1);
      renderScouting();
    });
  });
}

function escapeHtml(s) {
  if (!s) return '';
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

addScoutBtn.addEventListener('click', () => {
  scoutData.push({ name: '', caseType: '', notes: '' });
  renderScouting();
});

// ==================== Flow clear ====================
document.getElementById('clear-flow').addEventListener('click', () => {
  if (confirm('Clear flow notes for this round?')) {
    document.getElementById('flow-notes').value = '';
    document.getElementById('flow-round-label').value = '';
  }
});
</script>

